root = true

# ─────────────────────────────
# Base Settings
# ─────────────────────────────
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 2
tab_width = 2

# ─────────────────────────────
# Source Code Files
# ─────────────────────────────
[*.go]
indent_style = tab
tab_width = 4

# ─────────────────────────────
# Documents
# ─────────────────────────────
[*.md]
indent_style = space
indent_size = 2
tab_width = 2


# ─────────────────────────────
# configuration files
# ─────────────────────────────
[*.json]
indent_style = space
indent_size = 2
tab_width = 2

[*.{yaml,yml}]
indent_style = space
indent_size = 2
tab_width = 2

[*.ini]
indent_style = space
indent_size = 4
tab_width = 4

[*.toml]
indent_style = space
indent_size = 2
tab_width = 2

[*rc]
indent_style = space
indent_size = 2
tab_width = 2

# ─────────────────────────────
# Shell Scripts
# ─────────────────────────────
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2
tab_width = 2

# PowerShell
[*.ps1]
indent_style = space
indent_size = 4
tab_width = 4

# ─────────────────────────────
# Git Config Files
# ─────────────────────────────
[*.git*]
indent_style = tab
tab_width = 4

# ─────────────────────────────
# Special Files (e.g. Dockerfile, LICENSE)
# ─────────────────────────────
[{Makefile,*.mk}]
indent_style = tab
indent_size = 4
tab_width = 4

# ignore files
[**/*ignore]
indent_style = space
indent_size = 2
tab_width = 2

# [Dockerfile]
# indent_style = space
# indent_size = 2
